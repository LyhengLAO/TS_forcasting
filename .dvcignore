# ============================================================
# .dvcignore — fichiers que DVC ne doit PAS tracker
# Similaire à .gitignore mais pour DVC
# ============================================================

# Python cache
**/__pycache__
**/*.pyc
**/*.pyo

# Jupyter checkpoints
**/.ipynb_checkpoints

# Logs
**/logs/
**/*.log

# Temporary files
**/tmp/
**/*.tmp
**/*.temp

# OS files
**/.DS_Store
**/Thumbs.db

# IDE
**/.vscode/
**/.idea/

# MLflow (géré séparément)
mlruns/
mlartifacts/
